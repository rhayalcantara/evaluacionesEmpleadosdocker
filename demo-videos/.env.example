# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.

EVAL_BASE_URL=http://192.168.7.222/evaluacionempleado-prueba/

# Colaborador (videos 1 y 2)
EVAL_USERNAME=YOUR_USERNAME_HERE
EVAL_PASSWORD=YOUR_PASSWORD_HERE

# Supervisor (video 3) — optional; falls back to EVAL_USERNAME/EVAL_PASSWORD
EVAL_USERNAME_SUPER=YOUR_SUPERVISOR_USERNAME_HERE
EVAL_PASSWORD_SUPER=YOUR_SUPERVISOR_PASSWORD_HERE
